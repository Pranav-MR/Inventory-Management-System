generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PeriodUnit {
  DAY
  WEEK
  MONTH
  YEAR
}

enum BatchStatus {
  ACTIVE
  DEPLETED
  EXPIRED
  DISCARDED
}

enum NotificationChannelType {
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationEventType {
  LOW_STOCK
  STOCK_OUT_IMMINENT
  EXPIRY_WASTE_WARNING
  REQUEST_NEWER_BATCH
  CANDIDATE_BATCH_WASTE_WARNING
  UPCOMING_DELIVERY_REMINDER
}

enum ActivityType {
  ITEM_ADDED
  ITEM_EDITED
  ITEM_ARCHIVED
  ITEM_DELETED
  BATCH_ADDED
  BATCH_EDITED
  BATCH_DELETED
  CONSUMPTION_RECORDED
}

model User {
  id                String                    @id @default(cuid())
  email             String                    @unique
  passwordHash      String
  name              String?
  timezone          String                    @default("UTC")
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  items             Item[]
  notificationPrefs NotificationPreference[]
  notificationLogs  NotificationLog[]
  activityLogs      ActivityLog[]
  refreshTokens     RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Item {
  id                      String                   @id @default(cuid())
  userId                  String
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                    String
  category                String?
  unit                    String
  lowStockThreshold       Decimal?                 @db.Decimal(10, 3)
  isArchived              Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  consumptionRate         ConsumptionRate?
  recurringSupplySchedule RecurringSupplySchedule?
  batches                 Batch[]
  notificationLogs        NotificationLog[]
  activityLogs            ActivityLog[]
  consumptionEntries      ConsumptionEntry[]
  consumptionRateHistory  ConsumptionRateHistory[]

  @@index([userId])
}

model ConsumptionRate {
  id            String     @id @default(cuid())
  itemId        String     @unique
  item          Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  ratePerPeriod Decimal    @db.Decimal(10, 3)
  periodUnit    PeriodUnit
  updatedAt     DateTime   @updatedAt
}

/// Append-only history of every ConsumptionRate value the item has ever had,
/// purely for the "Average Consumption" chart — the live ConsumptionRate row
/// above remains the only value the prediction engine ever reads.
model ConsumptionRateHistory {
  id            String     @id @default(cuid())
  itemId        String
  item          Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  ratePerPeriod Decimal    @db.Decimal(10, 3)
  periodUnit    PeriodUnit
  effectiveFrom DateTime   @default(now())

  @@index([itemId, effectiveFrom])
}

model RecurringSupplySchedule {
  id                       String     @id @default(cuid())
  itemId                   String     @unique
  item                     Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  intervalValue            Int
  intervalUnit             PeriodUnit
  quantityPerDelivery      Decimal    @db.Decimal(10, 3)
  nextExpectedDeliveryDate DateTime
  assumedExpiryForFuture   DateTime?
  isActive                 Boolean    @default(true)
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
}

model Batch {
  id                     String                   @id @default(cuid())
  itemId                 String
  item                   Item                     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  batchLabel             String?
  receivedDate           DateTime
  expiryDate             DateTime
  quantityReceived       Decimal                  @db.Decimal(10, 3)
  quantityRemaining      Decimal                  @db.Decimal(10, 3)
  quantityAsOfDate       DateTime                 @default(now())
  status                 BatchStatus              @default(ACTIVE)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  consumptionAllocations ConsumptionAllocation[]

  @@index([itemId, expiryDate])
}

/// A single logged real-world consumption event. Never read by the prediction
/// engine — it exists purely for history/analytics and to keep batch
/// quantities accurate; see ConsumptionAllocation for how it maps to batches.
model ConsumptionEntry {
  id          String                   @id @default(cuid())
  itemId      String
  item        Item                     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  date        DateTime
  quantity    Decimal                  @db.Decimal(10, 3)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  allocations ConsumptionAllocation[]

  @@index([itemId, date])
}

/// Records exactly which batch(es) a ConsumptionEntry's FIFO deduction drew
/// from, and how much — so editing or deleting the entry can precisely
/// reverse its effect instead of re-deriving batch quantities from scratch.
model ConsumptionAllocation {
  id                 String           @id @default(cuid())
  consumptionEntryId String
  consumptionEntry   ConsumptionEntry @relation(fields: [consumptionEntryId], references: [id], onDelete: Cascade)
  batchId            String
  batch              Batch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  quantity           Decimal          @db.Decimal(10, 3)

  @@index([consumptionEntryId])
  @@index([batchId])
}

model NotificationPreference {
  id           String                  @id @default(cuid())
  userId       String
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType    NotificationEventType
  channel      NotificationChannelType @default(EMAIL)
  isEnabled    Boolean                 @default(true)
  leadTimeDays Int                     @default(7)
  updatedAt    DateTime                @updatedAt

  @@unique([userId, eventType, channel])
}

model NotificationLog {
  id        String                  @id @default(cuid())
  userId    String
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId    String?
  item      Item?                   @relation(fields: [itemId], references: [id], onDelete: SetNull)
  eventType NotificationEventType
  channel   NotificationChannelType
  subject   String
  body      String
  status    String
  error     String?
  sentAt    DateTime?
  dedupeKey String                  @unique
  createdAt DateTime                @default(now())

  @@index([userId, itemId])
}

model ActivityLog {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId    String?
  item      Item?        @relation(fields: [itemId], references: [id], onDelete: SetNull)
  itemName  String
  type      ActivityType
  message   String
  createdAt DateTime     @default(now())

  @@index([userId, createdAt])
}
